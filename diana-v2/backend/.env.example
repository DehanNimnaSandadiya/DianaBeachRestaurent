# ─────────────────────────────────────────────────────────────
# Diana Beach Restaurant — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Drivers → Python
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/diana_beach?retryWrites=true&w=majority

# Database name
DB_NAME=diana_beach

# JWT secret key — change this to any long random string
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Flask environment (development / production)
FLASK_ENV=development

# Admin credentials (used by seed script)
ADMIN_EMAIL=admin@dianabeach.lk
ADMIN_PASSWORD=Admin@Diana2025
